# ════════════════════════════════════════════════════════════════════════
# StockWatch Configuration
# Copy this file to .env.local for development, or set them in Vercel.
# All services listed here are completely FREE.
# ════════════════════════════════════════════════════════════════════════

# ------------------------------------------------------------------------
# 🔑 AUTH & SECURITY (Required)
# ------------------------------------------------------------------------

# 1. Generate password hash: Run `npm run hash-password -- <yourpassword>` in terminal.
# 2. Copy the resulting bcrypt hash output and paste it here:
APP_PASSWORD_HASH=

# Random 64-character hex string used for signing session JWTs.
# Generate in terminal: `openssl rand -hex 32` or use a long random alphanumeric string.
JWT_SECRET=

# Session duration in hours before the user is prompted to sign in again.
JWT_EXPIRY_HOURS=24

# ------------------------------------------------------------------------
# 🗄️ DATABASE (Upstash Redis - Required)
# ------------------------------------------------------------------------
# 1. Sign up for a free account at https://upstash.com/
# 2. Create a new Redis Database (Free Tier provides 10,000 requests/day).
# 3. Under the "Details" page, scroll down to the "REST API" section.
# 4. Copy the URL and REST Token, and paste them below:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ------------------------------------------------------------------------
# ⚡ CRON SECURITY & SCHEDULER (Upstash QStash - Required for hourly jobs)
# ------------------------------------------------------------------------
# A custom secret token to verify that incoming cron requests are coming from QStash.
# Generate: `openssl rand -hex 32` and paste it here:
CRON_SECRET=

# 1. In your Upstash console (https://console.upstash.com/), click "QStash" in the top bar.
# 2. Copy the "QSTASH_TOKEN" from the API Keys section on the right side and paste here:
QSTASH_TOKEN=

# The public URL of your deployed StockWatch web app (e.g. on Vercel).
# Used by QStash to ping your cron endpoints: /api/cron/*
# Set this to your localhost for testing (via a tunnel like ngrok) or your Vercel deployment URL.
APP_URL=https://your-app-name.vercel.app

# ------------------------------------------------------------------------
# 📈 ALERT SETTINGS (Optional)
# ------------------------------------------------------------------------
# Default hourly movement threshold (e.g., 5 means notify if a stock moves ±5% in an hour).
ALERT_THRESHOLD=5

# ------------------------------------------------------------------------
# 💬 TELEGRAM NOTIFICATIONS (Optional - Free Bot API)
# ------------------------------------------------------------------------
# 1. Open Telegram, search for the official account "@BotFather" and start a chat.
# 2. Send `/newbot`, name your bot, and copy the provided HTTP API Bot Token:
TELEGRAM_BOT_TOKEN=

# 3. Search for "@userinfobot" on Telegram, send any message, and copy your numeric ID:
TELEGRAM_PERSONAL_CHAT_ID=

# 4. (Optional) Create a group chat (e.g., family group), add your bot as a member, 
#    send a message in it, and fetch the chat ID from the bot API updates page:
#    Open in browser: `https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates`
#    Look for the "chat": { "id": -XXXXXXXXX } node (group IDs are negative numbers):
TELEGRAM_GROUP_CHAT_ID=

# ------------------------------------------------------------------------
# ✉️ GMAIL NOTIFICATIONS (Optional - Free SMTP Client)
# ------------------------------------------------------------------------
# 1. Log into your Google Account -> Google Security Settings page.
# 2. Enable "2-Step Verification" if not already active.
# 3. Search for "App Passwords" in the search bar.
# 4. Select App name (e.g. "StockWatch") and click "Create".
# 5. Copy the 16-character code and paste it below:
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
GMAIL_TO=recipient-email@gmail.com

# ------------------------------------------------------------------------
# 💬 WHATSAPP NOTIFICATIONS (Optional - Free Twilio WhatsApp Sandbox)
# ------------------------------------------------------------------------
# Set to 'true' to enable WhatsApp alerts, otherwise keep 'false'.
WHATSAPP_ENABLED=false

# 1. Sign up for a free developer account at https://www.twilio.com/
# 2. Copy the Account SID and Auth Token from your Console Dashboard:
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# 3. Go to "Develop -> Messaging -> Try it out -> Send a WhatsApp message" to set up Sandbox.
# 4. Copy the Sandbox sender number (format `whatsapp:+14155238886`):
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# 5. Opt-in on your phone by sending the specified keyword (e.g. "join <code-word>") 
#    to the Twilio Sandbox number. Do this for any recipient phone.
# 6. Fill in your personal WhatsApp receiver number (include country code, e.g. `whatsapp:+919876543210`):
WHATSAPP_PERSONAL_TO=

# 7. (Optional) Comma-separated list of family member numbers who opted in to the Twilio Sandbox:
WHATSAPP_FAMILY_TO=whatsapp:+919876543210,whatsapp:+919999999999

# ------------------------------------------------------------------------
# AI INSIGHT (OPTIONAL) — Get an AI-generated read on a stock you're viewing.
# ------------------------------------------------------------------------
# 1. Get a free API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# 2. Model name — check the current list at https://aistudio.google.com
#    for what's actually available under your key (model names and
#    availability change). Defaults to gemini-2.0-flash if left blank.
GEMINI_MODEL=gemini-2.0-flash
